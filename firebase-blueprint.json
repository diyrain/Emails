{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile for the letter writer",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "Letter": {
      "title": "Letter",
      "description": "A private letter addressed to someone in the future",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "recipient": { "type": "string" },
        "content": { "type": "string" },
        "mood": { "type": "string" },
        "weather": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "title", "content", "authorId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "letters/{letterId}": {
      "schema": "Letter",
      "description": "Collection of letters owned by users"
    }
  }
}
